<Window x:Class="CodexFloatingBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodexFloatingBar"
        Width="680"
        Height="176"
        MinWidth="680"
        MinHeight="176"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="CaptionText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#98FFFFFF" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F2FFFFFF" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="StatusPanel" TargetType="Border">
            <Setter Property="Background" Value="#181D23" />
            <Setter Property="BorderBrush" Value="#22FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FFFFFFFF" />
            <Setter Property="Background" Value="#2F7D52" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#359764" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#256A45" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="14"
            Background="#F20F1216"
            BorderBrush="#2EFFFFFF"
            BorderThickness="1"
            Padding="16"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="22" ShadowDepth="0" Opacity="0.32" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="34" Height="34" CornerRadius="9" Background="#22359764" BorderBrush="#55359764" BorderThickness="1">
                    <TextBlock Text="C" Foreground="#FF7DE3B2" FontWeight="Bold" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1" Margin="10,0,12,0" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Foreground="White" FontSize="15" FontWeight="SemiBold" Text="Codex 状态" />
                    <TextBlock x:Name="ModelText" Foreground="#CCFFFFFF" FontSize="12" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Border Grid.Column="2"
                        Height="30"
                        CornerRadius="8"
                        Background="#151FFFFFF"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="1"
                        Padding="10,0"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="AccountText"
                               Foreground="#D7FFFFFF"
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </Border>

                <Button Grid.Column="3" Content="↻" ToolTip="刷新" Click="RefreshClicked" />
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.12*" />
                    <ColumnDefinition Width="1.08*" />
                    <ColumnDefinition Width="1.35*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatusPanel}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionText}" Text="CONFIG" />
                        <TextBlock x:Name="ManualText" Style="{StaticResource ValueText}" Margin="0,4,0,0" MaxHeight="40" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StatusPanel}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionText}" Text="RUNTIME" />
                        <TextBlock x:Name="StateText" Style="{StaticResource ValueText}" Margin="0,4,0,0" MaxHeight="40" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource StatusPanel}" Margin="0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionText}" Text="ACCOUNT" />
                        <TextBlock x:Name="ConfigText" Style="{StaticResource ValueText}" Margin="0,4,0,0" MaxHeight="40" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="4" Height="1" Background="#1FFFFFFF" />
        </Grid>
    </Border>
</Window>
