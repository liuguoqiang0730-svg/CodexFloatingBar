<Window x:Class="CodexFloatingBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodexFloatingBar"
        Width="540"
        Height="112"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">
    <Border Background="#EE111111" CornerRadius="10" BorderBrush="#33FFFFFF" BorderThickness="1" Padding="14" SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock x:Name="TitleText" Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Codex 状态" />
                <TextBlock x:Name="ModelText" Foreground="#D9FFFFFF" Margin="0,4,0,0" TextWrapping="Wrap" />
                <TextBlock x:Name="StateText" Foreground="#D9FFFFFF" Margin="0,2,0,0" TextWrapping="Wrap" />
            </StackPanel>

            <Button Grid.Column="1" Width="32" Height="32" Margin="8,0,0,0" Content="↻" ToolTip="刷新" Click="RefreshClicked" />

            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" x:Name="ConfigText" Margin="0,10,0,0" Foreground="#C8FFFFFF" TextWrapping="Wrap" />
            <TextBlock Grid.Row="2" Grid.ColumnSpan="2" x:Name="ManualText" Margin="0,4,0,0" Foreground="#B0FFFFFF" TextWrapping="Wrap" />
        </Grid>
    </Border>
</Window>
