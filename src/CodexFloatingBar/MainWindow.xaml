<Window x:Class="CodexFloatingBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodexFloatingBar"
        Width="850"
        Height="118"
        MinWidth="560"
        MinHeight="92"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#F20F1216" />
        <SolidColorBrush x:Key="BorderBrushToken" Color="#2EFFFFFF" />
        <SolidColorBrush x:Key="CardBrush" Color="#181D23" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#22FFFFFF" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#D8FFFFFF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#98FFFFFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2F7D52" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#359764" />
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#256A45" />
        <SolidColorBrush x:Key="BadgeBrush" Color="#1FFFFFFF" />
        <SolidColorBrush x:Key="LogoBrush" Color="#22359764" />
        <SolidColorBrush x:Key="LogoBorderBrush" Color="#55359764" />
        <SolidColorBrush x:Key="LogoTextBrush" Color="#FF7DE3B2" />

        <Style x:Key="CaptionText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
        </Style>
        <Style x:Key="StatusPanel" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,7,0" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FFFFFFFF" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="Shell"
            CornerRadius="12"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrushToken}"
            BorderThickness="1"
            Padding="11"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="0" Opacity="0.28" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border x:Name="LogoMark" Width="28" Height="28" CornerRadius="8" Background="{DynamicResource LogoBrush}" BorderBrush="{DynamicResource LogoBorderBrush}" BorderThickness="1">
                    <TextBlock Text="C" Foreground="{DynamicResource LogoTextBrush}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <StackPanel x:Name="TitleStack" Grid.Column="1" Margin="9,0,10,0" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" FontWeight="SemiBold" Text="Codex Status" />
                    <TextBlock x:Name="ModelText" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                </StackPanel>

                <Border x:Name="AccountBadge"
                        Grid.Column="2"
                        Height="26"
                        MaxWidth="420"
                        CornerRadius="7"
                        Background="{DynamicResource BadgeBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        Padding="8,0"
                        Margin="0,0,7,0"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="AccountText"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                </Border>

                <Button x:Name="ThemeToggleButton" Grid.Column="3" Content="◐" ToolTip="切换主题" Click="ToggleThemeClicked" Margin="0,0,7,0" />

                <Button x:Name="LayoutToggleButton" Grid.Column="4" Content="↕" ToolTip="切换横竖版" Click="ToggleLayoutClicked" Margin="0,0,7,0" />

                <Button x:Name="HideButton" Grid.Column="5" Content="-" ToolTip="隐藏窗口" Click="HideClicked" Margin="0,0,7,0" />

                <Button x:Name="RefreshButton" Grid.Column="6" Content="↻" ToolTip="Refresh" Click="RefreshClicked" />
            </Grid>

            <Grid x:Name="StatusGrid" Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="StatusRow0" Height="*" />
                    <RowDefinition x:Name="StatusRow1" Height="0" />
                    <RowDefinition x:Name="StatusRow2" Height="0" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="StatusColumn0" Width="1.35*" />
                    <ColumnDefinition x:Name="StatusColumn1" Width="0.95*" />
                    <ColumnDefinition x:Name="StatusColumn2" Width="1.45*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="ConfigPanel" Grid.Row="0" Grid.Column="0" Style="{StaticResource StatusPanel}">
                    <StackPanel VerticalAlignment="Stretch">
                        <TextBlock x:Name="ConfigCaptionText" Style="{StaticResource CaptionText}" Text="CONFIG" />
                        <TextBlock x:Name="ManualText" Style="{StaticResource ValueText}" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border x:Name="RuntimePanel" Grid.Row="0" Grid.Column="1" Style="{StaticResource StatusPanel}">
                    <StackPanel VerticalAlignment="Stretch">
                        <TextBlock x:Name="RuntimeCaptionText" Style="{StaticResource CaptionText}" Text="SESSION" />
                        <TextBlock x:Name="StateText" Style="{StaticResource ValueText}" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border x:Name="UsagePanel" Grid.Row="0" Grid.Column="2" Style="{StaticResource StatusPanel}" Margin="0">
                    <StackPanel VerticalAlignment="Stretch">
                        <TextBlock x:Name="UsageCaptionText" Style="{StaticResource CaptionText}" Text="USAGE" />
                        <Grid x:Name="PrimaryUsageRow" Margin="0,3,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="PrimaryUsageLabel" Style="{StaticResource ValueText}" Text="5 小时" />
                            <Border Grid.Column="1" Height="10" Margin="9,0" VerticalAlignment="Center" Background="{DynamicResource BadgeBrush}" CornerRadius="5" ClipToBounds="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="PrimaryUsageFillColumn" Width="0*" />
                                        <ColumnDefinition x:Name="PrimaryUsageEmptyColumn" Width="100*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" CornerRadius="5" />
                                </Grid>
                            </Border>
                            <TextBlock x:Name="PrimaryUsageValue" Grid.Column="2" Style="{StaticResource ValueText}" />
                        </Grid>
                        <Grid x:Name="SecondaryUsageRow" Margin="0,3,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SecondaryUsageLabel" Style="{StaticResource ValueText}" Text="1 周" />
                            <Border Grid.Column="1" Height="10" Margin="9,0" VerticalAlignment="Center" Background="{DynamicResource BadgeBrush}" CornerRadius="5" ClipToBounds="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="SecondaryUsageFillColumn" Width="0*" />
                                        <ColumnDefinition x:Name="SecondaryUsageEmptyColumn" Width="100*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" CornerRadius="5" />
                                </Grid>
                            </Border>
                            <TextBlock x:Name="SecondaryUsageValue" Grid.Column="2" Style="{StaticResource ValueText}" />
                        </Grid>
                        <TextBlock x:Name="UsageUnavailableText" Style="{StaticResource ValueText}" Margin="0,2,0,0" Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </Grid>

            <ResizeGrip Grid.RowSpan="3"
                        Width="18"
                        Height="18"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Opacity="0.45"
                        Margin="0,0,-6,-6" />
        </Grid>
    </Border>
</Window>
